# ---- Telegram (required) ----
# Create a bot with @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your numeric chat id. Run:  python run.py --get-chat-id   (after messaging your bot once)
TELEGRAM_CHAT_ID=123456789

# ---- Claude AI analysis (optional) ----
# If set, a richer AI price-impact analysis is added on top of the free heuristics.
# Leave blank to run heuristics-only (no cost).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Tuning (optional, sensible defaults) ----
STEAM_APP_ID=730
STATE_FILE=state.json
FETCH_PRICES=true
CURRENCY=1
MAX_NEWS=10
